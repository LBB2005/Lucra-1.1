generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ── NextAuth v5 models ──────────────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // App relations
  holdings          Holding[]
  portfolioSettings PortfolioSettings?
  conversations     Conversation[]
  strategies        Strategy[]
  preference        UserPreference?
  briefings         Briefing[]
  backtests         Backtest[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ── App models ───────────────────────────────────────────────────────────────
model Holding {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticker      String
  companyName String?
  shares      Float
  avgCost     Float
  sector      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([ticker, userId])
  @@index([userId])
  @@map("holdings")
}

model PortfolioSettings {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cashBalance Float    @default(0)
  updatedAt   DateTime @updatedAt

  @@map("portfolio_settings")
}

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]

  @@index([userId])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           String
  content        String
  mode           String       @default("simple")
  agentTrace     String?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("messages")
}

// ── Agent memory + caching ───────────────────────────────────────────────────

model AgentCache {
  id        String   @id @default(cuid())
  cacheKey  String   @unique   // sha256(agentName + normalized input), first 16 hex chars
  agentName String
  result    String
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([agentName])
  @@index([expiresAt])
  @@map("agent_cache")
}

model TickerMemory {
  id        String   @id @default(cuid())
  ticker    String                          // uppercase, e.g. "AAPL"
  insight   String                          // 1-2 sentence distilled finding
  source    String?                         // which agent produced it
  createdAt DateTime @default(now())

  @@index([ticker, createdAt])
  @@map("ticker_memory")
}

model MarkovResult {
  id        String   @id @default(cuid())
  ticker    String
  years     Int      @default(5)
  result    String   // JSON-encoded MarkovData
  createdAt DateTime @default(now())

  @@unique([ticker, years])
  @@index([createdAt])
  @@map("markov_results")
}

model Strategy {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  tag       String
  desc      String   @default("")
  tickers   String   @default("[]")    // JSON: string[]
  config    String   @default("{}")    // JSON: bot execution parameters
  research  String   @default("")     // markdown: rationale, data, prior research
  sharpe    Float    @default(0)
  cagr      Float    @default(0)
  maxDD     Float    @default(0)
  winRate   Float    @default(0)
  active    Boolean  @default(false)
  lastTrade String   @default("—")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("strategies")
}

// ── User preference (investing style memory) ─────────────────────────────────

model UserPreference {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  style     String   @default("{}")  // JSON: { horizon, riskTolerance, style, sectors, priorities }
  updatedAt DateTime @updatedAt

  @@map("user_preferences")
}

// ── Weekly briefings ──────────────────────────────────────────────────────────

model Briefing {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String                        // markdown report
  tickers   String   @default("[]")       // JSON: string[] — tickers covered
  readAt    DateTime?                     // null = unread
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@map("briefings")
}

// ── NL backtests ──────────────────────────────────────────────────────────────

model Backtest {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  query     String                        // original NL query
  config    String   @default("{}")       // JSON: parsed strategy config
  result    String   @default("{}")       // JSON: BacktestResult
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("backtests")
}
